{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["es2015", "dom", "dom.iterable", "es2022", "webworker"],
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,

    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": ["src"]
}
